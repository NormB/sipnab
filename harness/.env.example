# Copy to .env and adjust. `make up` / docker compose read this automatically.

COMPOSE_PROJECT_NAME=sipnab-harness

# ---- Network ----------------------------------------------------------------
SIPNET_SUBNET=172.28.0.0/24
OPENSIPS_IP=172.28.0.10
UAS_IP=172.28.0.20
UAC_IP=172.28.0.21

# ---- Published ports (host side) -------------------------------------------
# Internal ports are fixed (opensips on 5060, rtpengine 30000-30050). These
# are the HOST-side published ports -- change them if the host already runs a
# service on the default (e.g. a host OpenSIPS on udp/5060).
SIP_HOST_PORT=5060     # host port -> opensips-1:5060 (laptop registers/calls here)
MCP_PORT=8731          # host port -> sipnab MCP HTTP (laptop agent connects here)
RTP_MIN=30000          # rtpengine media range (published udp), keep <= RTP_MAX
RTP_MAX=30050

# ---- sipnab MCP -------------------------------------------------------------
# Host header the MCP server will accept. The laptop reaches this box by IP or
# DNS name; rmcp's DNS-rebind guard rejects unknown Host values. Set this to
# your host's name/IP, or leave "*" (host-check disabled) and rely on the
# bearer token + a network firewall. The token is ALWAYS required on the
# non-loopback bind regardless of this value.
SIPNAB_MCP_ALLOWED_HOST=*

# ---- OpenSIPS source (built from your fork at your local HEAD) --------------
OPENSIPS_GIT_URL=https://github.com/NormB/opensips.git
OPENSIPS_GIT_REF=d8586fa6

# ---- Traffic generator ------------------------------------------------------
LOOP_PAUSE=5           # seconds between UAC scenario iterations
