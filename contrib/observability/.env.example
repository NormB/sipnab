# Copy to .env and edit for your environment.
#
# ── sipnab on the same host as the compose stack (default) ──────────
# Containers reach sipnab via Docker's host-gateway alias.
#
#   SIPNAB_HOST=host-gateway
#
# ── sipnab on a remote host ─────────────────────────────────────────
# Set SIPNAB_HOST to the remote host's IP or DNS name. Prometheus
# inside the stack will then scrape <SIPNAB_HOST>:9100.
#
#   SIPNAB_HOST=192.0.2.10
#   SIPNAB_HOST=capture.example.com

SIPNAB_HOST=host-gateway

# Retention windows.
PROM_RETENTION=30d

# Grafana admin credentials. Defaults are fine for development against
# localhost; change before exposing the stack anywhere wider.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANON=false

# Host port mappings. Override if these collide with anything local.
PROM_PORT=9090
GRAFANA_PORT=3000
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
